rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default — only explicit matches below can read or write.

    match /users/{userId} {
      // Owner can read and delete their top-level user document.
      // Cloud Functions (Admin SDK) create it — no client create needed.
      allow read, delete: if request.auth != null && request.auth.uid == userId;

      // All subcollections: only the owner can read/write.
      // Covers: night_events, drink_entries, drink_types, challenges,
      //         profiles, ai_coach_reports, night_recoveries.
      // Cloud Functions write via Admin SDK which bypasses these rules.
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

  }
}
